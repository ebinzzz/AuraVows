# Set these as Environment Variables in the Railway dashboard
# Never commit real secrets to version control

# PostgreSQL — Railway provides this automatically if you add a Postgres plugin
DATABASE_URL=postgresql://postgres:password@host:5432/railway

# JWT Secret — generate a strong random string
SECRET_KEY=change-this-to-a-long-random-secret-key

# JWT Settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS — set this to your Vercel frontend URL (no trailing slash)
# Example: https://your-wedding-app.vercel.app
ALLOWED_ORIGINS=https://your-wedding-app.vercel.app
